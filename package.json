{
  "name": "etvr-firmware-flasher-tool",
  "version": "1.8.0",
  "private": true,
  "description": "A SolidJS project for EyeTrackVR",
  "author": "EyeTrackVR",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "vite preview",
    "setup": "pnpm install",
    "tauri:dev": "tauri dev",
    "tauri:dev:release": "tauri dev --release",
    "tauri:build": "tauri build",
    "tauri:build:dev": "tauri build --debug",
    "tauri:update": "cd src-tauri && cargo update && cargo upgrade",
    "tauri:clean": "cd src-tauri && cargo clean",
    "docs": "jsdoc -c jsdoc.conf.json",
    "lint": "eslint --ext .js,.ts,.jsx,.tsx src",
    "format": "pnpm run lint --fix & pnpm prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "update-deps": "pnpm up -Li",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@kobalte/tailwindcss": "^0.9.0",
    "@optimize-lodash/rollup-plugin": "^6.0.0",
    "@solidjs/router": "^0.15.4",
    "@storybook/addon-docs": "^10.2.8",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-log": "~2",
    "@tauri-apps/plugin-notification": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "~2",
    "@tauri-apps/plugin-upload": "~2.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "daisyui": "^5.5.18",
    "eslint-config-google": "^0.14.0",
    "lodash": "^4.17.23",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.3",
    "solidjs-use": "^2.3.0",
    "storybook": "^10.2.8",
    "storybook-solidjs-vite": "^10.0.9",
    "tailwindcss": "3.4.17",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.2.3",
    "jsdom": "^28.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}