{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "EyeTrackVR Firmware Flashing Tool",
  "mainBinaryName": "EyeTrackVR Firmware Flashing Tool",
  "version": "1.8.0",
  "identifier": "com.eyetrackvrfft.dev",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 750,
        "width": 750,
        "resizable": true,
        "center": true,
        "title": "EyeTrackVR Firmware Flashing Tool",
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "trayIcon": {
      "iconPath": "../public/images/icons/icon-48x48.png",
      "iconAsTemplate": true
    },
    "security": {
      "capabilities": [
        {
          "identifier": "draggable-window",
          "windows": [
            "*"
          ],
          "permissions": [
            "core:window:allow-start-dragging",
            "core:window:allow-toggle-maximize",
            "core:window:allow-internal-toggle-maximize",
            "core:window:allow-close",
            "core:window:allow-minimize",
            "core:app:allow-version",
            "log:default",
            "notification:allow-request-permission",
            "notification:default",
            "core:path:allow-resolve-directory",
            "core:path:allow-join",
            "core:path:default",
            "core:event:allow-listen",
            "store:default",
            "core:event:default",
            "upload:default",
            {
              "identifier": "http:default",
              "allow": [
                {
                  "url": "https://api.github.com/repos/EyeTrackVR/OpenIris-ESPIDF/releases/latest"
                }
              ]
            },
            "fs:allow-remove",
            {
              "identifier": "fs:scope",
              "allow": [
                {
                  "path": "$APPDATA/**"
                }
              ]
            }
          ]
        }
      ],
      "assetProtocol": {
        "scope": [
          "$APPCONFIG/*",
          "$APPDATA/*",
          "$RESOURCE/*"
        ],
        "enable": true
      },
      "dangerousDisableAssetCspModification": [
        "script-src"
      ],
      "csp": "script-src: 'self' https://unpkg.com/esp-web-tools@9.2.0/dist/web/install-button.js?module; default-src blob: data: filesystem: ws: wss: http: https: tauri: 'unsafe-eval' 'unsafe-inline' 'self' img-src: 'self' asset: https://asset.localhost media-src stream: https://stream.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "Developer Tool",
    "copyright": "EyeTrackVR Firmware Flashing Tool",
    "icon": [
      "../public/images/icons/icon-48x48.png",
      "../public/images/icons/icon-128x128.png",
      "../public/images/icons/icon-144x144.png",
      "../public/images/icons/favicon.ico"
    ],
    "longDescription": "",
    "shortDescription": "",
    "resources": [],
    "externalBin": [],
    "targets": "all",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "allowDowngrades": false,
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": [
          "en-US"
        ]
      }
    }
  }
}